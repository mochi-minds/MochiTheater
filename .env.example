# --- Etherlink (EVM L2) ---
# Network: "shadownet" or "mainnet"
NEXT_PUBLIC_ETHERLINK_NETWORK=shadownet
# Contract address (set after deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# --- Tezos L1 ---
# Network: "shadownet" or "mainnet"
NEXT_PUBLIC_TEZOS_NETWORK=shadownet
# Contract address (set after deployment)
NEXT_PUBLIC_TEZOS_CONTRACT_ADDRESS=KT1...

# --- API keys (server-side only — no NEXT_PUBLIC_ prefix) ---
ANTHROPIC_API_KEY=sk-ant-...
